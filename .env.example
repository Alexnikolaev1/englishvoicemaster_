# ═══════════════════════════════════════════════════════════════════
#   EnglishVoiceMaster — Environment Variables
#   Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── 1. Telegram Bot Token ───────────────────────────────────────────
# Get from @BotFather → /newbot
BOT_TOKEN=your_telegram_bot_token_here

# ── 2. Yandex Cloud ─────────────────────────────────────────────────
# console.cloud.yandex.ru → Service Accounts → Create → API Key
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_yandex_folder_id

# SpeechKit key (can be the same as YANDEX_API_KEY)
SPEECHKIT_API_KEY=your_speechkit_api_key

# ── 3. Database ──────────────────────────────────────────────────────
# LOCAL (docker-compose): postgresql+asyncpg://postgres:postgres@localhost:55432/englishvoicemaster
# LOCAL (native Postgres): postgresql+asyncpg://postgres:password@localhost:5432/englishvoicemaster
# VERCEL:  Use Neon (neon.tech) — free tier available
#          postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/evm?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:55432/englishvoicemaster

# ── 4. YuKassa Payments ──────────────────────────────────────────────
# merchant.yookassa.ru → Settings → API Keys
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key

# ── 5. Webhook (Vercel deployment) ──────────────────────────────────
# Set DEPLOY_MODE=vercel on Vercel (or leave empty for local polling)
DEPLOY_MODE=local

# Your Vercel deployment URL (auto-set by Vercel as VERCEL_URL)
# If deploying manually, set this:
# WEBHOOK_URL=https://your-app.vercel.app

# Secret token for webhook security (any random string, 16+ chars)
WEBHOOK_SECRET=change_this_to_a_random_secret_string

# ── 6. Admin Access ──────────────────────────────────────────────────
# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789

# ── 7. Bot Settings ──────────────────────────────────────────────────
FREE_TRIAL_DAYS=3
FREE_TRIAL_MESSAGES=20
