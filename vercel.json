{
  "version": 2,
  "name": "englishvoicemaster",
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py",
      "methods": ["POST", "GET"]
    },
    {
      "src": "/api/setup_webhook",
      "dest": "/api/setup_webhook.py",
      "methods": ["GET"]
    },
    {
      "src": "/",
      "dest": "/api/webhook.py",
      "methods": ["GET"]
    }
  ],
  "functions": {
    "api/webhook.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/setup_webhook.py": {
      "maxDuration": 15
    }
  },
  "env": {
    "DEPLOY_MODE": "vercel"
  }
}
